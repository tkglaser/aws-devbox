{
  "name": "devbox",
  "version": "0.1.0",
  "scripts": {
    "start": "npm run pre-deployment && npm run deploy && npm run post-deployment",
    "stop": "ts-node -r dotenv/config scripts/stop.ts",
    "destroy": "ts-node scripts/destroy.ts",
    "pre-deployment": "ts-node ./scripts/pre-deployment.ts",
    "deploy": "ts-node scripts/deploy.ts",
    "post-deployment": "ts-node ./scripts/post-deployment.ts",
    "cdk": "cdk",
    "format": "npx @biomejs/biome format --write",
    "lint": "npx @biomejs/biome lint --write",
    "check": "npx @biomejs/biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/cross-spawn": "~6.0.6",
    "@types/jest": "~29.4.0",
    "@types/lodash": "~4.17.23",
    "@types/node": "^24",
    "@types/superagent": "~8.1.9",
    "aws-cdk": "^2",
    "jest": "~29.5.0",
    "ts-jest": "~29.0.5",
    "ts-node": "~10.9.1",
    "typescript": "~5.1.6"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "~3.983.0",
    "@aws-sdk/credential-provider-node": "~3.972.5",
    "aws-cdk-lib": "^2",
    "constructs": "^10.0.0",
    "cross-spawn": "~7.0.6",
    "dotenv": "~17.2.3",
    "lodash": "~4.18.1",
    "source-map-support": "~0.5.21",
    "superagent": "~10.3.0"
  }
}
